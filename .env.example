# 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
# LLM (Anthropic-compatible API，如 OpenRouter / Anthropic 直连)
LLM_API_KEY=
LLM_BASE_URL=http://127.0.0.1:15721
LLM_MODEL=claude-sonnet-4-6[1M]
# Neon PostgreSQL (需要加 ?sslmode=require，代码已通过 connect_args 处理 SSL)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname
# Redis (MVP-0 可选)
REDIS_URL=redis://localhost:6379/0
# App
ENV=dev
